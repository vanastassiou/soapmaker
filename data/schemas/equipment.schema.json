{
  "$id": "equipment.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": {
    "$ref": "#/definitions/Equipment"
  },
  "definitions": {
    "Equipment": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "description": "Display name of the equipment",
          "minLength": 1,
          "type": "string"
        },
        "category": {
          "description": "Equipment category",
          "enum": [
            "mould",
            "mixing",
            "measuring",
            "safety",
            "cutting",
            "storage"
          ],
          "type": "string"
        },
        "description": {
          "description": "Brief description of the equipment and its purpose",
          "minLength": 1,
          "type": "string"
        },
        "details": {
          "description": "Extended information including selection tips and usage notes",
          "type": "string"
        },
        "considerations": {
          "description": "Key factors when selecting this equipment",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "safetyNotes": {
          "description": "Important safety information",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "related": {
          "description": "IDs of related equipment or glossary terms",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "references": {
          "$ref": "common-definitions.schema.json#/definitions/references"
        },
        "domain": {
          "description": "Knowledge section(s) where this equipment appears",
          "items": {
            "enum": ["craft", "calculator"],
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "name",
        "category",
        "description",
        "domain"
      ],
      "type": "object"
    }
  },
  "description": "Schema for soapmaking equipment and tools",
  "title": "Soapmaking Equipment",
  "type": "object"
}
